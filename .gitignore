# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
# generated sign-pdf test fixtures (recreate with scripts/make-test-pdfs.mjs)
/scripts/fixtures/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local Claude Code tooling (machine-specific dev config)
.claude/

# raw certificate/source files — converted + optimized into /public/images/certificates
/src/images/

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
